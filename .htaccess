# Enable mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Set the base directory
  RewriteBase /

  # Remove .html extension from URLs
  # Rewrite login to login.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.html [L]

  # Rewrite /admin/dashboard to /admin/dashboard.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^admin/([a-zA-Z0-9_-]+)/?$ admin/$1.html [L]

  # Redirect /login.html requests to /login (optional, for cleaner URLs)
  RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
  RewriteRule ^ /%1 [NC,L,R=301]

  # Prevent direct access to .html files
  RewriteCond %{THE_REQUEST} /.*\.html
  RewriteRule ^.*$ - [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Cache control
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
</IfModule>
